# ==========================================
# Data Science Specific
# ==========================================
# Never commit raw or processed datasets
data/**/*
# ...except for the .gitkeep files that preserve your empty folder structure
!data/**/.gitkeep

# Never commit serialized models/scalers (which can be massive)
models/**/*
!models/**/.gitkeep
*.pkl
*.h5
*.joblib
*.onnx

# ==========================================
# Credentials and Secrets
# ==========================================
# Private environment variables, API keys, and tokens
.env
.envrc
secrets.*

# ==========================================
# Python & Virtual Environments
# ==========================================
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
*.so

# Virtual Environments
.venv/
venv/
env/
ENV/
pip-log.txt
pip-delete-this-directory.txt

# Distribution / packaging
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# ==========================================
# Jupyter Notebooks
# ==========================================
.ipynb_checkpoints/
*/.ipynb_checkpoints/*
# Inline Jupyter graphics/outputs (optional, but keeps diffs clean)
# .ipynb_checkpoints

# ==========================================
# Operating System & IDEs
# ==========================================
# Windows system files
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# macOS system files
.DS_Store
.AppleDouble
.LSOverride

# VS Code
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# PyCharm / IntelliJ
.idea/